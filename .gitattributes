# Normalize line endings: store LF in the repo, let Git decide per-platform for text.
* text=auto

# Files that MUST keep LF even on Windows checkouts — shell scripts here are
# bind-mounted into Linux containers (e.g. build/ollama/entrypoint.sh) and
# CRLF endings break /bin/sh.
*.sh text eol=lf
Makefile text eol=lf
makefile text eol=lf

# Windows scripts keep CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets — never touch line endings.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

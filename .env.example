APP_NAME=QForge

CONTAINER_NAME_PREFIX=qforge_
NETWORK=qforge_local

PROJECT_PATH=/var/www

USERID=1000

PHP_FPM_VERSION=8.5-fpm-bookworm
MYSQL_VERSION=8.4

NGINX_HTTP_PORT=8040
FRONTEND_PORT=5173
PYTHON_PORT=8000

# M5 — local LLM (Ollama) for AI bank expansion. LLM_PROVIDER=stub bypasses Ollama.
LLM_PROVIDER=ollama
OLLAMA_URL=http://qforge_ollama:11434
OLLAMA_MODEL=qwen2.5:3b-instruct
LLM_DEBUG=false

# M6 — RAG (see docs/RAG-GUIDE.md).
OLLAMA_EMBED_MODEL=nomic-embed-text
QDRANT_PORT=6333

HOST_DB_PORT=3307
FORWARD_REDIS_PORT=6379
FORWARD_MAILPIT_PORT=1025
FORWARD_MAILPIT_DASHBOARD_PORT=8025

MYSQL_DATABASE=qforge_db
MYSQL_ROOT_PASSWORD=root
MYSQL_USER=qforge
MYSQL_USER_PASSWORD=secret
